# ── Provider selection ────────────────────────────────────────────────────────
# Set to "deepseek" (default) or "groq"
# deepseek config set provider groq

# ── DeepSeek (default provider) ───────────────────────────────────────────────
# Get yours at: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-...

# DeepSeek model to use (optional, default: deepseek-chat)
# Options: deepseek-chat, deepseek-reasoner
DEEPSEEK_MODEL=deepseek-chat

# ── Groq ──────────────────────────────────────────────────────────────────────
# Get yours at: https://console.groq.com/keys
GROQ_API_KEY=gsk_...

# Groq model to use (optional, default: llama-3.3-70b-versatile)
# Popular options: llama-3.3-70b-versatile, llama-3.1-8b-instant,
#                  mixtral-8x7b-32768, gemma2-9b-it
GROQ_MODEL=llama-3.3-70b-versatile

# Tavily API Key for web search (optional)
# Get yours at: https://app.tavily.com
TAVILY_API_KEY=tvly-...

# Max tokens per response (optional, default: 8192)
DEEPSEEK_MAX_TOKENS=8192

# Temperature (optional, default: 0)
DEEPSEEK_TEMPERATURE=0

# Enable debug logging (optional)
DEBUG=false
